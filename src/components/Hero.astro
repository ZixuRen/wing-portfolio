---
import DigitalTwin from './DigitalTwin/DigitalTwin.jsx';
---

<section class="hero">
  <!-- Cream upper zone -->
  <div class="hero__top">
    <nav class="hero__nav">
      <a href="/" class="hero__nav-name">Wing Ren</a>
      <div class="hero__nav-links">
        <a href="#about">About</a>
        <a href="#works">Works</a>
        <a href="#contact">Contact</a>
      </div>
    </nav>
  </div>

  <!-- Headline — positioned at the boundary -->
  <div class="hero__headline-wrap">
    <h1 class="hero__headline">
      Designing how<br />
      <em>people</em> connect<br />
      with <em>AI</em>
    </h1>
    <p class="hero__subtitle">AI Product Designer / Creative Technologist / Interaction Designer</p>
  </div>

  <!-- Organic divider line (SVG) -->
  <div class="hero__divider" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,35 C180,55 360,10 540,30 C720,50 900,5 1080,25 C1200,38 1350,15 1440,28" fill="none" stroke="var(--color-black)" stroke-width="1" />
    </svg>
  </div>

  <!-- Yellow lower zone — Interactive Digital Twin Island -->
  <div class="hero__bottom">
    <DigitalTwin client:visible />

  </div>
</section>

<div class="hero__footer-sticky">
  <footer class="hero__footer">
    <div class="hero__footer-left">
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="mailto:hello@wingren.com">Email</a>
    </div>
    <div class="hero__footer-right">
      <a href="/Wing_Ren_CV.pdf" download>Download my CV</a>
    </div>
  </footer>
</div>

<style>
  .hero {
    position: relative;
    display: grid;
    grid-template-rows: 1fr auto auto 1fr;
    min-height: 100vh;
    min-height: 100dvh;
  }

  /* --- Cream top zone --- */
  .hero__top {
    background-color: var(--color-cream);
    padding: var(--space-lg) var(--space-xl);
  }

  .hero__nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero__nav-name {
    font-weight: 700;
  }

  .hero__nav-links {
    display: flex;
    gap: var(--space-lg);
  }

  .hero__nav-links a:hover {
    opacity: 0.6;
  }

  /* --- Headline zone — spans the boundary --- */
  .hero__headline-wrap {
    position: relative;
    z-index: 2;
    background-color: var(--color-cream);
    padding: 0 var(--space-xl);
    padding-bottom: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero__headline {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 7.5vw, 7rem);
    font-weight: 400;
    line-height: 1.05;
    color: var(--color-black);
    letter-spacing: -0.01em;
  }

  .hero__headline em {
    font-style: italic;
    font-weight: 600;
  }

  .hero__subtitle {
    margin-top: var(--space-md);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-black);
    opacity: 0.6;
  }

  /* --- Organic divider --- */
  .hero__divider {
    position: relative;
    z-index: 3;
    height: 60px;
    margin-top: -30px;
    margin-bottom: -30px;
    pointer-events: none;
  }

  .hero__divider svg {
    width: 100%;
    height: 100%;
  }

  /* --- Yellow bottom zone --- */
  .hero__bottom {
    background-color: var(--color-yellow);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    padding-bottom: var(--space-lg);
    gap: var(--space-xl);
    position: relative;
    overflow: hidden;
  }

  .hero__footer-sticky {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-yellow);
    padding: var(--space-md) var(--space-xl);
  }

  .hero__footer {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hero__footer-left {
    display: flex;
    gap: var(--space-lg);
  }

  .hero__footer-left a:hover {
    opacity: 0.6;
  }

  .hero__footer-right a:hover {
    opacity: 0.6;
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .hero__top {
      padding: var(--space-md) var(--space-lg);
    }

    .hero__headline-wrap {
      padding: 0 var(--space-lg);
      padding-bottom: var(--space-lg);
    }

    .hero__bottom {
      padding: var(--space-lg);
    }

    .hero__headline {
      font-size: clamp(2rem, 8vw, 3.5rem);
    }

    .hero__nav-links {
      gap: var(--space-md);
    }
  }
</style>
